#!/usr/bin/env bash
# LazyMind CLI wrapper — delegates to cli/ Python package.
set -euo pipefail

# Use BASH_SOURCE so the script resolves its own directory even if $0 is
# empty (e.g. when sourced in unusual ways).
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# The CLI uses Python 3-only APIs (e.g. Path.unlink(missing_ok=...)), so
# fail fast with a clear message if python3 is missing rather than falling
# back to a bare `python` that might be Python 2 or an unsupported 3.x.
if command -v python3 &>/dev/null; then
    PYTHON=python3
else
    echo "error: python3 not found (LazyMind CLI requires Python 3.9+)" >&2
    exit 1
fi

# Repo root for cli/, algorithm/lazyllm for lazyllm, algorithm/ for chat.*
# Only add the lazyllm submodule path if it's actually populated, so an
# uninitialised submodule doesn't shadow a pip-installed lazyllm.
LAZYLLM_DIR="${SCRIPT_DIR}/algorithm/lazyllm"
EXTRA_PATHS="${SCRIPT_DIR}:${SCRIPT_DIR}/algorithm"
if [ -d "${LAZYLLM_DIR}" ] && [ -n "$(ls -A "${LAZYLLM_DIR}" 2>/dev/null)" ]; then
    EXTRA_PATHS="${SCRIPT_DIR}:${LAZYLLM_DIR}:${SCRIPT_DIR}/algorithm"
fi
export PYTHONPATH="${EXTRA_PATHS}${PYTHONPATH:+:$PYTHONPATH}"
exec "$PYTHON" -m cli "$@"
